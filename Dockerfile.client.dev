FROM node:22-slim

WORKDIR /app

COPY package*.json ./
COPY client/package*.json ./client/

RUN npm install --workspace=client

COPY client/ ./client/

EXPOSE 5173

# Vite dev server — listens on all interfaces so Docker port mapping works
CMD ["npm", "run", "dev", "--workspace=client", "--", "--host", "0.0.0.0"]
