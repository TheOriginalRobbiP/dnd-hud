# Copy to .env on the VPS and fill in values

# Postgres password — pick something strong
POSTGRES_PASSWORD=changeme

# Full DB URL (optional — defaults to db container above)
# DATABASE_URL=postgresql://hud:changeme@db:5432/the_hud

# Domain for nginx (set this in Dokploy's proxy settings, not here)
# DOMAIN=dnd.rjp.digital

# GM dashboard PIN (players will be prompted for this to access GM view)
GM_PIN=your-pin-here
