FROM node:22-slim

WORKDIR /app/server

# Install deps directly inside server dir (avoids workspace hoisting issues)
COPY server/package*.json ./
RUN npm install

# Copy source and build
COPY server/ ./
RUN npm run build

# Copy startup script
WORKDIR /app
COPY startup.sh ./startup.sh
RUN chmod +x ./startup.sh

EXPOSE 3001

CMD ["./startup.sh"]
